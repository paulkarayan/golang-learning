#!/usr/bin/env bash
set -e

echo "==> Running pre-commit checks..."

echo "==> gofmt"
UNFORMATTED=$(gofmt -l .)
if [ -n "$UNFORMATTED" ]; then
    echo "Files not formatted:"
    echo "$UNFORMATTED"
    echo "Run: gofmt -w ."
    exit 1
fi

echo "==> go vet"
go vet ./...

echo "==> golangci-lint"
if command -v golangci-lint &> /dev/null; then
    golangci-lint run ./...
else
    echo "  (skipped — golangci-lint not installed)"
fi

echo "==> All pre-commit checks passed."
