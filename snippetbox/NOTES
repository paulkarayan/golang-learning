go mod init snippetbox.paulkarayan.com

go run .

---
go run ./cmd/web

# 1. Homepage - GET /                                                                        
  curl -v http://localhost:4000/                                                               
                                                                                               
  # 2. View a snippet - GET /snippet/view/{id}                                                 
  curl -v http://localhost:4000/snippet/view/1                                                 
                                                                                               
  # 3. View snippet with invalid ID (should return 404)                                        
  curl -v http://localhost:4000/snippet/view/0
  curl -v http://localhost:4000/snippet/view/-1
  curl -v http://localhost:4000/snippet/view/abc

  # 4. Show create form - GET /snippet/create
  curl -v http://localhost:4000/snippet/create

  # 5. Create a snippet - POST /snippet/create (returns 201)
  curl -v -X POST http://localhost:4000/snippet/create

  # 6. Wrong method on create form (POST to view, GET handled differently)
  curl -v -X POST http://localhost:4000/snippet/view/1

  # 7. Non-existent route (should 404)
  curl -v http://localhost:4000/foo/bar

  # 8. Check the custom Server header on home
  curl -sI http://localhost:4000/ | grep Server


---
go build -o sbox ./cmd/cli/
go run ./cmd/cli/main.go